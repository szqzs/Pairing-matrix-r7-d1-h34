{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "commandTranscript": {
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string"
        },
        "duration_seconds": {
          "minimum": 0,
          "type": "number"
        },
        "exit_code": {
          "type": "integer"
        },
        "stderr_bytes": {
          "minimum": 0,
          "type": "integer"
        },
        "stderr_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "stdout_bytes": {
          "minimum": 0,
          "type": "integer"
        },
        "stdout_sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "required": [
        "command",
        "exit_code",
        "stdout_sha256",
        "stderr_sha256",
        "stdout_bytes",
        "stderr_bytes",
        "duration_seconds"
      ],
      "type": "object"
    },
    "determinantMinor": {
      "additionalProperties": false,
      "properties": {
        "chern_degree": {
          "type": "integer"
        },
        "columns": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "expected_det_mod": {
          "type": "integer"
        },
        "matrix_mod_prime": {
          "items": {
            "items": {
              "type": "integer"
            },
            "type": "array"
          },
          "type": "array"
        },
        "name": {
          "type": "string"
        },
        "observed_det_mod": {
          "type": "integer"
        },
        "passed": {
          "type": "boolean"
        },
        "prime": {
          "type": "integer"
        },
        "rows": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "name",
        "chern_degree",
        "rows",
        "columns",
        "prime",
        "expected_det_mod",
        "observed_det_mod",
        "passed",
        "matrix_mod_prime"
      ],
      "type": "object"
    },
    "environment": {
      "additionalProperties": false,
      "properties": {
        "executable": {
          "type": "string"
        },
        "jsonschema": {
          "type": [
            "string",
            "null"
          ]
        },
        "platform": {
          "type": "string"
        },
        "pytest": {
          "type": [
            "string",
            "null"
          ]
        },
        "python": {
          "type": "string"
        },
        "sympy": {
          "type": "string"
        }
      },
      "required": [
        "executable",
        "python",
        "platform",
        "sympy",
        "pytest",
        "jsonschema"
      ],
      "type": "object"
    },
    "integerMap": {
      "additionalProperties": {
        "type": "integer"
      },
      "type": "object"
    },
    "passedMap": {
      "additionalProperties": {
        "type": "boolean"
      },
      "type": "object"
    },
    "rank7Problem": {
      "additionalProperties": false,
      "properties": {
        "determinant_degree": {
          "type": "integer"
        },
        "expected_relation_chern_degree": {
          "type": "integer"
        },
        "genus": {
          "type": "integer"
        },
        "rank": {
          "type": "integer"
        },
        "source_degree": {
          "type": "integer"
        },
        "test_degree": {
          "type": "integer"
        },
        "top_degree": {
          "type": "integer"
        }
      },
      "required": [
        "rank",
        "genus",
        "determinant_degree",
        "source_degree",
        "test_degree",
        "expected_relation_chern_degree",
        "top_degree"
      ],
      "type": "object"
    },
    "sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "sha256Map": {
      "additionalProperties": {
        "$ref": "#/$defs/sha256"
      },
      "type": "object"
    },
    "sourceState": {
      "additionalProperties": false,
      "properties": {
        "git_dirty": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "git_head": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "git_head",
        "git_dirty"
      ],
      "type": "object"
    }
  },
  "additionalProperties": false,
  "oneOf": [
    {
      "properties": {
        "gate": {
          "const": "Gate B: rank-5 public regression"
        }
      },
      "required": [
        "rank5_regression",
        "structural_checks",
        "old_rank5_repo_reference"
      ]
    },
    {
      "properties": {
        "gate": {
          "const": "Gate C: rank-7 residue-transition smoke"
        }
      },
      "required": [
        "github_repository",
        "github_remote_head",
        "residue_transition_smoke"
      ]
    }
  ],
  "properties": {
    "command_transcripts": {
      "items": {
        "$ref": "#/$defs/commandTranscript"
      },
      "type": "array"
    },
    "commands": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "environment": {
      "$ref": "#/$defs/environment"
    },
    "gate": {
      "enum": [
        "Gate B: rank-5 public regression",
        "Gate C: rank-7 residue-transition smoke"
      ]
    },
    "generated_at_utc": {
      "format": "date-time",
      "type": "string"
    },
    "github_remote_head": {
      "type": [
        "string",
        "null"
      ]
    },
    "github_repository": {
      "type": "string"
    },
    "old_rank5_repo_reference": {
      "additionalProperties": false,
      "properties": {
        "certificate_sha256": {
          "$ref": "#/$defs/sha256Map",
          "minProperties": 11
        },
        "computed_columns_sha256": {
          "$ref": "#/$defs/sha256Map",
          "minProperties": 11
        },
        "git_dirty": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "git_head": {
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "type": "string"
        },
        "summary_sha256": {
          "anyOf": [
            {
              "$ref": "#/$defs/sha256"
            },
            {
              "type": "null"
            }
          ]
        },
        "usage": {
          "type": "string"
        }
      },
      "required": [
        "path",
        "git_head",
        "git_dirty",
        "usage",
        "certificate_sha256",
        "computed_columns_sha256",
        "summary_sha256"
      ],
      "type": "object"
    },
    "project_root": {
      "type": "string"
    },
    "rank5_regression": {
      "additionalProperties": false,
      "properties": {
        "c20_minor": {
          "$ref": "#/$defs/determinantMinor"
        },
        "executable_minor_results": {
          "items": {
            "$ref": "#/$defs/determinantMinor"
          },
          "maxItems": 4,
          "minItems": 4,
          "type": "array"
        },
        "genus": {
          "type": "integer"
        },
        "public_minor_summaries": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "chern_degree": {
                "type": "integer"
              },
              "expected_det_mod": {
                "type": "integer"
              },
              "prime": {
                "type": "integer"
              },
              "rank": {
                "type": "integer"
              },
              "source_dimension": {
                "type": "integer"
              }
            },
            "required": [
              "chern_degree",
              "source_dimension",
              "rank",
              "prime",
              "expected_det_mod"
            ],
            "type": "object"
          },
          "maxItems": 11,
          "minItems": 11,
          "type": "array"
        },
        "rank": {
          "type": "integer"
        },
        "scalar_results": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "expected_mod": {
                "type": "integer"
              },
              "left": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "observed_mod": {
                "type": "integer"
              },
              "passed": {
                "type": "boolean"
              },
              "prime": {
                "type": "integer"
              },
              "right": {
                "type": "string"
              }
            },
            "required": [
              "name",
              "left",
              "right",
              "prime",
              "expected_mod",
              "observed_mod",
              "passed"
            ],
            "type": "object"
          },
          "maxItems": 5,
          "minItems": 5,
          "type": "array"
        },
        "top_degree": {
          "type": "integer"
        }
      },
      "required": [
        "rank",
        "genus",
        "top_degree",
        "scalar_results",
        "public_minor_summaries",
        "executable_minor_results",
        "c20_minor"
      ],
      "type": "object"
    },
    "rank7_problem": {
      "$ref": "#/$defs/rank7Problem"
    },
    "residue_transition_smoke": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "alpha": {
            "items": {
              "type": "integer"
            },
            "type": "array"
          },
          "derivative_orders": {
            "items": {
              "type": "integer"
            },
            "type": "array"
          },
          "expected_mod": {
            "$ref": "#/$defs/integerMap",
            "minProperties": 2
          },
          "name": {
            "type": "string"
          },
          "observed_mod": {
            "$ref": "#/$defs/integerMap",
            "minProperties": 2
          },
          "passed": {
            "type": "boolean"
          },
          "passed_by_prime": {
            "$ref": "#/$defs/passedMap",
            "minProperties": 2
          },
          "root_power": {
            "type": "integer"
          }
        },
        "required": [
          "name",
          "alpha",
          "derivative_orders",
          "root_power",
          "observed_mod",
          "expected_mod",
          "passed",
          "passed_by_prime"
        ],
        "type": "object"
      },
      "maxItems": 5,
      "minItems": 5,
      "type": "array"
    },
    "schema_sha256": {
      "anyOf": [
        {
          "$ref": "#/$defs/sha256"
        },
        {
          "type": "null"
        }
      ]
    },
    "schema_version": {
      "const": 1
    },
    "source_state": {
      "$ref": "#/$defs/sourceState"
    },
    "source_tree_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "status": {
      "enum": [
        "passed",
        "failed"
      ]
    },
    "structural_checks": {
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "gate",
    "generated_at_utc",
    "status",
    "project_root",
    "source_tree_sha256",
    "source_state",
    "schema_sha256",
    "environment",
    "commands",
    "command_transcripts",
    "rank7_problem"
  ],
  "title": "Rank JK Math Gate Artifact",
  "type": "object"
}
